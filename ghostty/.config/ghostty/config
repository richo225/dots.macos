# Font
font-family = CaskaydiaMono Nerd Font
font-size = 16

# Window
window-padding-x = 16
window-padding-y = 16
background-opacity = 0.92
macos-titlebar-style = hidden

# Terminal — Ghostty defaults to xterm-ghostty; override to match Alacritty
term = xterm-256color

# Colours — generated by theme-set, not committed
config-file = ~/.config/ghostty/colors.conf

# Keybindings
keybind = f11=toggle_fullscreen
keybind = shift+enter=text:\x1b\r
